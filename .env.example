# Research Toolkit Configuration
# All features work without API keys (using free alternatives)

# Optional: GNews API key (for enhanced news search)
# Get free key at: https://gnews.io/
GNEWS_API_KEY=

# Optional: Bluesky account (for enhanced Bluesky search)
# Create app password at: https://bsky.app/settings/app-passwords
BLUESKY_IDENTIFIER=
BLUESKY_PASSWORD=

# Optional: Stack Exchange API key (increases daily quota from 300 to 10,000)
# Register at: https://stackapps.com/apps/oauth/register
STACKEXCHANGE_API_KEY=

# Optional: Configure video analysis
# WHISPER_MODEL=base
# MAX_VIDEO_DURATION=600
