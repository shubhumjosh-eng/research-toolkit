{
  "name": "research-toolkit",
  "version": "3.1.0",
  "description": "Deep research assistant for the terminal — searches 10 platforms (Reddit, YouTube, Hacker News, Bluesky, Discourse, Stack Exchange, News, Web, Semantic Scholar, arXiv) with smart query understanding, TF-IDF ranking, and parallel fetching",
  "main": "src/cli.js",
  "bin": {
    "research": "./src/cli.js"
  },
  "scripts": {
    "start": "node src/cli.js",
    "research": "node src/cli.js",
    "tui": "node src/cli.js",
    "batch": "node src/cli.js --batch",
    "web": "node src/server.js",
    "test": "node src/cli.js --batch \"test\" --depth 100"
  },
  "keywords": [
    "research",
    "deep-research",
    "web-analysis",
    "terminal",
    "tui",
    "reddit",
    "youtube",
    "hacker-news",
    "bluesky",
    "discourse",
    "stack-overflow",
    "ai",
    "search",
    "analysis"
  ],
  "author": "Research Toolkit Contributors",
  "license": "BSL-1.1",
  "dependencies": {
    "axios": "^1.18.1",
    "cheerio": "^1.2.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "ink": "^3.2.0",
    "puppeteer": "^24.43.1",
    "react": "^18.3.1",
    "ws": "^8.21.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
